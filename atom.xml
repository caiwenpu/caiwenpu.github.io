    <content type="html"><![CDATA[<h1 id="python-&#x5E38;&#x7528;&#x4EE3;&#x7801;"><a href="#python-&#x5E38;&#x7528;&#x4EE3;&#x7801;" class="headerlink" title="python &#x5E38;&#x7528;&#x4EE3;&#x7801;"></a>python &#x5E38;&#x7528;&#x4EE3;&#x7801;</h1><h2 id="CUDA&#x73AF;&#x5883;&#x53D8;&#x91CF;&#x8BBE;&#x7F6E;"><a href="#CUDA&#x73AF;&#x5883;&#x53D8;&#x91CF;&#x8BBE;&#x7F6E;" class="headerlink" title="CUDA&#x73AF;&#x5883;&#x53D8;&#x91CF;&#x8BBE;&#x7F6E;"></a>CUDA&#x73AF;&#x5883;&#x53D8;&#x91CF;&#x8BBE;&#x7F6E;</h2><figure class="highlight python"><table><tr><td class="gutter"><pre><div class="line">1</div></pre></td><td class="code"><pre><div class="line">os.environ[<span class="string">&apos;CUDA_VISIBLE_DEVICES&apos;</span>] = <span class="string">&apos;0&apos;</span></div></pre></td></tr></table></figure><h2 id="&#x6D4B;&#x8BD5;&#x7A0B;&#x5E8F;&#x8FD0;&#x884C;&#x65F6;&#x95F4;"><a href="#&#x6D4B;&#x8BD5;&#x7A0B;&#x5E8F;&#x8FD0;&#x884C;&#x65F6;&#x95F4;" class="headerlink" title="&#x6D4B;&#x8BD5;&#x7A0B;&#x5E8F;&#x8FD0;&#x884C;&#x65F6;&#x95F4;"></a>&#x6D4B;&#x8BD5;&#x7A0B;&#x5E8F;&#x8FD0;&#x884C;&#x65F6;&#x95F4;</h2><figure class="highlight python"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div><div class="line">3</div></pre></td><td class="code"><pre><div class="line"><span class="keyword">import</span> time</div><div class="line">start = time.clock()</div><div class="line">elapsed = (time.clock() - start)</div></pre></td></tr></table></figure><h2 id="&#x6570;&#x7EC4;&#x64CD;&#x4F5C;"><a href="#&#x6570;&#x7EC4;&#x64CD;&#x4F5C;" class="headerlink" title="&#x6570;&#x7EC4;&#x64CD;&#x4F5C;"></a>&#x6570;&#x7EC4;&#x64CD;&#x4F5C;</h2><h3 id="&#x62F7;&#x8D1D;"><a href="#&#x62F7;&#x8D1D;" class="headerlink" title="&#x62F7;&#x8D1D;"></a>&#x62F7;&#x8D1D;</h3><figure class="highlight python"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div><div class="line">3</div><div class="line">4</div></pre></td><td class="code"><pre><div class="line"><span class="keyword">import</span> numpy <span class="keyword">as</span> np</div><div class="line">A = np.array([<span class="number">1</span>,<span class="number">2</span>,<span class="number">3</span>,<span class="number">4</span>,<span class="number">5</span>])</div><div class="line">B = A.copy() <span class="comment">#B&#x6307;&#x5411;&#x4E00;&#x5757;&#x65B0;&#x7684;&#x533A;&#x57DF;</span></div><div class="line">C = A <span class="comment">#C&#x6307;&#x5411;A&#x7684;&#x7A7A;&#x95F4;</span></div></pre></td></tr></table></figure><h3 id="&#x53D6;&#x503C;"><a href="#&#x53D6;&#x503C;" class="headerlink" title="&#x53D6;&#x503C;"></a>&#x53D6;&#x503C;</h3><figure class="highlight python"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div><div class="line">3</div><div class="line">4</div></pre></td><td class="code"><pre><div class="line"><span class="keyword">import</span> numpy <span class="keyword">as</span> np</div><div class="line">A = np.array([<span class="number">1</span>,<span class="number">2</span>,<span class="number">3</span>,<span class="number">4</span>,<span class="number">5</span>])</div><div class="line">B = A[:<span class="number">-1</span>] <span class="comment">#&#x53D6;&#x9664;&#x53BB;&#x6700;&#x540E;&#x4E00;&#x4E2A;&#x5143;&#x7D20;</span></div><div class="line">C = A[::<span class="number">2</span>] <span class="comment"># step = 2&#x53D6;A&#x4E2D;&#x7684;&#x5143;&#x7D20;</span></div></pre></td></tr></table></figure><h2 id="pycuda"><a href="#pycuda" class="headerlink" title="pycuda"></a>pycuda</h2><figure class="highlight python"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div><div class="line">3</div><div class="line">4</div><div class="line">5</div><div class="line">6</div><div class="line">7</div><div class="line">8</div><div class="line">9</div><div class="line">10</div><div class="line">11</div><div class="line">12</div><div class="line">13</div><div class="line">14</div><div class="line">15</div></pre></td><td class="code"><pre><div class="line"><span class="keyword">import</span> pycuda.driver <span class="keyword">as</span> cuda</div><div class="line"><span class="keyword">import</span> pycuda.autoinit</div><div class="line"><span class="keyword">from</span> pycuda.compiler <span class="keyword">import</span> SourceModule</div><div class="line"><span class="keyword">import</span> numpy</div><div class="line">a = numpy.random.randn(<span class="number">4</span>,<span class="number">4</span>)</div><div class="line">a = a.astype(numpy.float32)</div><div class="line">mod = SourceModule(<span class="string">&quot;&quot;&quot;</span></div><div class="line"><span class="string">  __global__ void doublify(float *a)</span></div><div class="line"><span class="string">  {</span></div><div class="line"><span class="string">    int idx = threadIdx.x + threadIdx.y*4;</span></div><div class="line"><span class="string">    a[idx] *= 2;</span></div><div class="line"><span class="string">  }</span></div><div class="line"><span class="string">  &quot;&quot;&quot;</span>)</div><div class="line">func = mod.get_function(<span class="string">&quot;doublify&quot;</span>)</div><div class="line">func(cuda.InOut(a), block=(<span class="number">4</span>,<span class="number">4</span>,<span class="number">1</span>))</div></pre></td></tr></table></figure><h2 id="seaborn"><a href="#seaborn" class="headerlink" title="seaborn"></a>seaborn</h2><p><a href="https://seaborn.pydata.org/api.html" target="_blank" rel="external">seaborn API</a></p><h3 id="&#x8054;&#x5408;&#x5206;&#x5E03;"><a href="#&#x8054;&#x5408;&#x5206;&#x5E03;" class="headerlink" title="&#x8054;&#x5408;&#x5206;&#x5E03;"></a>&#x8054;&#x5408;&#x5206;&#x5E03;</h3><figure class="highlight python"><table><tr><td class="gutter"><pre><div class="line">1</div></pre></td><td class="code"><pre><div class="line">seaborn.jointplot(x, y, data=<span class="keyword">None</span>, kind=<span class="string">&apos;scatter&apos;</span>, stat_func=&lt;function pearsonr&gt;, color=<span class="keyword">None</span>, size=<span class="number">6</span>, ratio=<span class="number">5</span>, space=<span class="number">0.2</span>, dropna=<span class="keyword">True</span>, xlim=<span class="keyword">None</span>, ylim=<span class="keyword">None</span>, joint_kws=<span class="keyword">None</span>, marginal_kws=<span class="keyword">None</span>, annot_kws=<span class="keyword">None</span>, **kwargs)</div></pre></td></tr></table></figure><p>Parameters:</p><ul><li><code>edge_color = &apos;w&apos; #&#x4F7F;&#x5F97;&#x6563;&#x70B9;&#x56FE;&#x6BCF;&#x4E2A;&#x70B9;&#x53D8;&#x5C0F;</code>  </li><li><code>marginal_kws = dict(bins=1000) #&#x4F7F;&#x5F97;&#x76F4;&#x65B9;&#x56FE;&#x7C92;&#x5EA6;&#x66F4;&#x5C0F;</code>  </li></ul><h3 id="&#x76F4;&#x65B9;&#x56FE;"><a href="#&#x76F4;&#x65B9;&#x56FE;" class="headerlink" title="&#x76F4;&#x65B9;&#x56FE;"></a>&#x76F4;&#x65B9;&#x56FE;</h3><figure class="highlight python"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div><div class="line">3</div><div class="line">4</div><div class="line">5</div></pre></td><td class="code"><pre><div class="line">seaborn.distplot(x,kde=Falsen,norm_hist = <span class="keyword">True</span>)</div><div class="line">plt.yscale(<span class="string">&quot;log&quot;</span>,nonposy=<span class="string">&apos;clip&apos;</span>) <span class="comment">#&#x6CE8;&#x610F;&#x4E00;&#x5B9A;&#x8981;&#x52A0;&#x540E;&#x9762;&#x4E00;&#x9879;&#x53C2;&#x6570;&#xFF0C;&#x9632;&#x6B62;log0&#x65E0;&#x5B9A;&#x4E49; &#x5BF9;&#x5E94;plt.xscale(&apos;log&apos;,nonposx=&apos;clip&apos;)</span></div><div class="line">plt.yscale(min,max)</div><div class="line">plt.xscale(min,max)</div><div class="line">plt.savefig(filepath)</div></pre></td></tr></table></figure><h2 id="&#x6587;&#x4EF6;&#x8BFB;&#x5165;&#xFF0C;&#x5199;&#x51FA;"><a href="#&#x6587;&#x4EF6;&#x8BFB;&#x5165;&#xFF0C;&#x5199;&#x51FA;" class="headerlink" title="&#x6587;&#x4EF6;&#x8BFB;&#x5165;&#xFF0C;&#x5199;&#x51FA;"></a>&#x6587;&#x4EF6;&#x8BFB;&#x5165;&#xFF0C;&#x5199;&#x51FA;</h2><h3 id="numpy&#x6570;&#x7EC4;"><a href="#numpy&#x6570;&#x7EC4;" class="headerlink" title="numpy&#x6570;&#x7EC4;"></a>numpy&#x6570;&#x7EC4;</h3><p>API: <code>numpy.savetxt(filename|handle,numpy.array)</code>;<code>numpy.loadtxt(filename)</code><br><figure class="highlight python"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div><div class="line">3</div><div class="line">4</div><div class="line">5</div><div class="line">6</div></pre></td><td class="code"><pre><div class="line">f = open(<span class="string">&apos;asd.txt&apos;</span>, <span class="string">&apos;ab&apos;</span>)</div><div class="line"><span class="keyword">for</span> iind <span class="keyword">in</span> range(<span class="number">4</span>):</div><div class="line">    a = np.random.rand(<span class="number">2</span>, <span class="number">2</span>)</div><div class="line">    np.savetxt(f, a)</div><div class="line">f.close()</div><div class="line">print(np.loadtxt(<span class="string">&quot;asd.txt&quot;</span>))</div></pre></td></tr></table></figure></p><h3 id="dict"><a href="#dict" class="headerlink" title="dict"></a>dict</h3><figure class="highlight python"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div></pre></td><td class="code"><pre><div class="line">json.dump(dict, open(file, <span class="string">&apos;w&apos;</span>))</div><div class="line">json.load(open(file))</div></pre></td></tr></table></figure><h1 id="Tensorflow"><a href="#Tensorflow" class="headerlink" title="Tensorflow"></a>Tensorflow</h1><figure class="highlight python"><table><tr><td class="gutter"><pre><div class="line">1</div></pre></td><td class="code"><pre><div class="line">dtype = <span class="string">&apos;float32&apos;</span>  <span class="string">&apos;float64&apos;</span>  <span class="string">&apos;int32&apos;</span>  <span class="string">&apos;int64&apos;</span> <span class="string">&apos;int&apos;</span></div></pre></td></tr></table></figure>]]></content>
    
