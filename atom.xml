&#x4E4B;&#x540E;&#x663E;&#x8457;&#x63D0;&#x9AD8;&#x5404;&#x79CD;&#x5E93;&#x7684;&#x4E0B;&#x8F7D;&#x901F;&#x5EA6;</p><h1 id="&#x8BBE;&#x7F6E;&#x73AF;&#x5883;&#x53D8;&#x91CF;"><a href="#&#x8BBE;&#x7F6E;&#x73AF;&#x5883;&#x53D8;&#x91CF;" class="headerlink" title="&#x8BBE;&#x7F6E;&#x73AF;&#x5883;&#x53D8;&#x91CF;"></a>&#x8BBE;&#x7F6E;&#x73AF;&#x5883;&#x53D8;&#x91CF;</h1><h3 id="C"><a href="#C" class="headerlink" title="C++"></a>C++</h3><figure class="highlight c++"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div></pre></td><td class="code"><pre><div class="line"><span class="meta">#<span class="meta-keyword">include</span> <span class="meta-string">&lt;stdlib.h&gt;</span></span></div><div class="line"><span class="function"><span class="keyword">int</span> <span class="title">setenv</span><span class="params">(<span class="keyword">const</span> <span class="keyword">char</span> *name, <span class="keyword">const</span> <span class="keyword">char</span> *value, <span class="keyword">int</span> overwrite)</span></span>;<span class="comment">//overwrite &#x8BBE;&#x7F6E;&#x4E3A; 1</span></div></pre></td></tr></table></figure><h2 id=""><a href="#" class="headerlink" title="#"></a>#</h2><figure class="highlight bash"><table><tr><td class="gutter"><pre><div class="line">1</div></pre></td><td class="code"><pre><div class="line"><span class="built_in">alias</span> <span class="comment">#&#x53EA;&#x662F;&#x8BBE;&#x7F6E;&#x4E00;&#x4E2A;&#x522B;&#x540D;&#xFF0C;&#x53EA;&#x5728;shell&#x7EC8;&#x7AEF;&#x91CC;&#x6709;&#x6548;&#xFF0C;&#x5728;Makefile&#x7B49;&#x6587;&#x4EF6;&#x91CC;&#x65E0;&#x6548;</span></div></pre></td></tr></table></figure><h1 id="linux-&#x547D;&#x4EE4;"><a href="#linux-&#x547D;&#x4EE4;" class="headerlink" title="linux &#x547D;&#x4EE4;"></a>linux &#x547D;&#x4EE4;</h1><h2 id="&#x63A7;&#x5236;&#x53F0;&#x547D;&#x4EE4;"><a href="#&#x63A7;&#x5236;&#x53F0;&#x547D;&#x4EE4;" class="headerlink" title="&#x63A7;&#x5236;&#x53F0;&#x547D;&#x4EE4;"></a>&#x63A7;&#x5236;&#x53F0;&#x547D;&#x4EE4;</h2><figure class="highlight bash"><table><tr><td class="gutter"><pre><div class="line">1</div><div class="line">2</div><div class="line">3</div><div class="line">4</div><div class="line">5</div><div class="line">6</div></pre></td><td class="code"><pre><div class="line">Ctrl+a &#x5149;&#x6807;&#x79FB;&#x52A8;&#x5230;&#x5F00;&#x59CB;&#x5904;</div><div class="line">Ctrl+e &#x5149;&#x6807;&#x79FB;&#x52A8;&#x5230;&#x6700;&#x672B;&#x5C3E;</div><div class="line">Ctrl+d &#x5220;&#x9664;&#x5F53;&#x524D;&#x5B57;&#x7B26;</div><div class="line">Ctrl+w &#x5220;&#x9664;(&#x526A;&#x5207;)&#x6B64;&#x5904;&#x5DE6;&#x8FB9;&#x7684;&#x5355;&#x8BCD;</div><div class="line">Ctrl+y &#x7C98;&#x8D34;&#x7531;Ctrl+w&#x5220;&#x9664;&#x7684;&#x5355;&#x8BCD;</div><div class="line">Ctrl+&#x5DE6;&#x53F3; &#x79FB;&#x52A8;&#x4E00;&#x4E2A;&#x5355;&#x8BCD;</div></pre></td></tr></table></figure><h2 id="&#x5E38;&#x7528;&#x547D;&#x4EE4;"><a href="#&#x5E38;&#x7528;&#x547D;&#x4EE4;" class="headerlink" title="&#x5E38;&#x7528;&#x547D;&#x4EE4;"></a>&#x5E38;&#x7528;&#x547D;&#x4EE4;</h2><h3 id="&#x663E;&#x793A;&#x6307;&#x5B9A;&#x76EE;&#x5F55;&#x5927;&#x5C0F;"><a href="#&#x663E;&#x793A;&#x6307;&#x5B9A;&#x76EE;&#x5F55;&#x5927;&#x5C0F;" class="headerlink" title="&#x663E;&#x793A;&#x6307;&#x5B9A;&#x76EE;&#x5F55;&#x5927;&#x5C0F;"></a>&#x663E;&#x793A;&#x6307;&#x5B9A;&#x76EE;&#x5F55;&#x5927;&#x5C0F;</h3><figure class="highlight bash"><table><tr><td class="gutter"><pre><div class="line">1</div></pre></td><td class="code"><pre><div class="line">du -h dir/</div></pre></td></tr></table></figure><h3 id="&#x7EDF;&#x8BA1;&#x6587;&#x4EF6;&#x6570;&#x76EE;"><a href="#&#x7EDF;&#x8BA1;&#x6587;&#x4EF6;&#x6570;&#x76EE;" class="headerlink" title="&#x7EDF;&#x8BA1;&#x6587;&#x4EF6;&#x6570;&#x76EE;"></a>&#x7EDF;&#x8BA1;&#x6587;&#x4EF6;&#x6570;&#x76EE;</h3><figure class="highlight bash"><table><tr><td class="gutter"><pre><div class="line">1</div></pre></td><td class="code"><pre><div class="line